# Anthropic — used by lib/anthropic.ts (new Anthropic() reads this automatically)
ANTHROPIC_API_KEY=sk-ant-...

# Neon Postgres — used by lib/db.ts via @vercel/postgres
# Grab from Neon dashboard -> Connection Details -> "Pooled connection".
# IMPORTANT: must be the *pooled* endpoint (host contains "-pooler"). The direct
# endpoint will exhaust connections under serverless load.
# Format: postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/DB?sslmode=require
POSTGRES_URL=postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/devdoc?sslmode=require
